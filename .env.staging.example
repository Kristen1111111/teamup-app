# =============================================================================
# .env.staging.example — gabarit pour l'environnement de DEV/STAGING isolé
# =============================================================================
#
# Copier en `.env` (ou `.env.local`) EN LOCAL une fois le projet staging créé :
#   cp .env.staging.example .env
# puis remplacer les placeholders ci-dessous par les valeurs du projet staging
# (Studio staging > Project Settings > Data API : Project URL + clé publishable).
#
# OBJECTIF : que `npm run dev` tape sur la base STAGING, jamais sur la prod
# `yljskqyvqumvtmvptkxt`. Aucune activité/notif de test ne doit polluer la prod.
#
# Ces deux variables sont publiques (exposées au navigateur via Vite). La clé
# publishable n'est PAS un secret de service — la sécurité repose sur la RLS.

VITE_SUPABASE_URL=https://<STAGING_PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<STAGING_PUBLISHABLE_OR_ANON_KEY>

# Démo auto-seedée par-user au login (bootstrap_demo, etc.). OFF par défaut.
# On peut la mettre à "true" en staging pour remplir les comptes de contenu
# fictif. A laisser unset/false en prod (vrais signups = comptes vides).
# VITE_DEMO_SEED=true
