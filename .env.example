VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Demo seeding — OFF by default. Set to "true" ONLY on a throwaway demo
# deployment to auto-fill each account with fictional content at login.
# Leave unset/false in production so real signups start with an empty account.
# VITE_DEMO_SEED=true
